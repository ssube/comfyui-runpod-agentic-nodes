#!/usr/bin/env bash
set -euo pipefail

python_bin="${PYTHON:-$(pwd)/venv/bin/python}"

"$python_bin" -m ruff check comfyui_runpod_agentic tests
"$python_bin" -m pytest
"$python_bin" -m build

scripts/e2e-local-runtime
scripts/e2e-local-keepalive-timeout
scripts/e2e-local-container-snapshot-live
scripts/e2e-local-build-then-run-image

if [[ "${CRAG_RUN_COMFY_E2E:-0}" == "1" ]]; then
  scripts/e2e-comfy-cpu --skip-clone
  scripts/e2e-comfy-local-runtime --skip-clone
  scripts/e2e-comfy-local-agent-skills --skip-clone
  scripts/e2e-comfy-local-ollama-deepseek --skip-clone
  scripts/e2e-comfy-container-snapshot --skip-clone
fi

if [[ "${CRAG_RUN_OLLAMA_E2E:-0}" == "1" ]]; then
  scripts/e2e-local-browser-screenshot-live
  scripts/e2e-local-mcp-ollama-cloud-live
  scripts/e2e-local-subagent-ollama-cloud-live
fi
