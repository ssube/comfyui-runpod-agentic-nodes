{
  "templates": [
    {
      "containerDiskInGb": 20,
      "dockerArgs": "sleep infinity",
      "imageName": "runpod/pytorch:2.8.0-py3.11-cuda12.8.1-cudnn-devel-ubuntu22.04",
      "key": "rp-agent-pi",
      "name": "crag-agent-pi",
      "ports": "22/tcp",
      "readme": "CRAG agent template placeholder. Replace with an image containing /usr/local/bin/runpod-agent-launch.",
      "volumeInGb": 10,
      "volumeMountPath": "/workspace"
    },
    {
      "containerDiskInGb": 30,
      "dockerArgs": "sleep infinity",
      "imageName": "runpod/pytorch:2.8.0-py3.11-cuda12.8.1-cudnn-devel-ubuntu22.04",
      "key": "rp-agent-opencode",
      "name": "crag-agent-opencode",
      "ports": "22/tcp",
      "readme": "CRAG OpenCode agent template placeholder. Bake OpenCode and runpod-agent-launch before production use.",
      "volumeInGb": 10,
      "volumeMountPath": "/workspace"
    },
    {
      "containerDiskInGb": 10,
      "dockerArgs": "sleep infinity",
      "imageName": "mcr.microsoft.com/playwright:v1.56.1-noble",
      "key": "rp-browser-playwright",
      "name": "crag-browser-playwright",
      "ports": "3000/http,22/tcp",
      "readme": "CRAG Playwright browser placeholder. Add a websocket server command before production use.",
      "volumeInGb": 0
    },
    {
      "containerDiskInGb": 10,
      "dockerArgs": "",
      "imageName": "ghcr.io/m1k1o/neko/chromium:latest",
      "key": "rp-browser-neko",
      "name": "crag-browser-neko",
      "ports": "8080/http,22/tcp",
      "readme": "CRAG Neko browser template.",
      "volumeInGb": 0
    },
    {
      "containerDiskInGb": 20,
      "dockerArgs": "serve",
      "imageName": "ollama/ollama:0.12.10",
      "key": "rp-llm-ollama",
      "name": "crag-llm-ollama",
      "ports": "11434/http,22/tcp",
      "readme": "CRAG Ollama LLM server template.",
      "volumeInGb": 20,
      "volumeMountPath": "/root/.ollama"
    },
    {
      "containerDiskInGb": 10,
      "imageName": "qdrant/qdrant:v1.16.2",
      "key": "rp-vector-qdrant",
      "name": "crag-vector-qdrant",
      "ports": "6333/http,22/tcp",
      "readme": "CRAG Qdrant vector database template.",
      "volumeInGb": 10,
      "volumeMountPath": "/qdrant/storage"
    },
    {
      "containerDiskInGb": 10,
      "env": [
        {
          "key": "POSTGRES_DB",
          "value": "app"
        },
        {
          "key": "POSTGRES_USER",
          "value": "app"
        }
      ],
      "imageName": "postgres:17.7",
      "key": "rp-db-postgres",
      "name": "crag-db-postgres",
      "ports": "5432/tcp,22/tcp",
      "readme": "CRAG Postgres template. Provide POSTGRES_PASSWORD via Runpod secret/env at deploy time.",
      "volumeInGb": 10,
      "volumeMountPath": "/var/lib/postgresql/data"
    }
  ]
