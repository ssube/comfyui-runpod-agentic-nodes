{
  "1": {
    "class_type": "SSHCommand",
    "inputs": {
      "command": "mkdir -p /workspace/e2e && printf 'startup-one\\n' > /workspace/e2e/command-1.txt && printf '%s\\n' \"$OLLAMA_HOST\" > /workspace/e2e/ollama-host.txt",
      "phase": "before_start",
      "failure_policy": "fail",
      "retry_count": 0
    }
  },
  "2": {
    "class_type": "SSHCommand",
    "inputs": {
      "previous": [
        "1",
        0
      ],
      "command": "test -s /workspace/e2e/command-1.txt && printf 'startup-two\\n' > /workspace/e2e/command-2.txt",
      "phase": "before_start",
      "failure_policy": "fail",
      "retry_count": 0
    }
  },
  "3": {
    "class_type": "LLMServer",
    "inputs": {
      "engine": "Ollama",
      "model": "smoke",
      "placement": "own_pod",
      "api_auth_mode": "none",
      "api_key_secret_name": "",
      "hf_token_secret_name": ""
    }
  },
  "4": {
    "class_type": "Agent",
    "inputs": {
      "harness": "Pi",
      "model": "smoke",
      "startup_mode": "manual",
      "workspace_path": "/workspace",
      "system_prompt": "You are a local runtime e2e agent.",
      "llm": [
        "3",
        0
      ]
    }
  },
  "5": {
    "class_type": "Deploy",
    "inputs": {
      "app": [
        "4",
        0
      ],
      "commands": [
        "2",
        0
      ]
    }
  },
  "6": {
    "class_type": "RunLocalContainers",
    "inputs": {
      "prompt": "Launch the local runtime e2e stack.",
      "deployment": [
        "5",
        0
      ],
      "project_name": "crag-comfy-local-e2e",
      "output_path": "artifacts/local-runtime/comfy-e2e-compose.yaml",
      "action": "apply",
      "use_sudo": true,
      "timeout_seconds": 600,
      "response_role": "agent",
      "response_path": "/workspace/e2e/command-2.txt",
      "response_timeout_seconds": 120,
      "reuse_policy": "reuse_matching",
      "engine": "containerd"
    }
  }
}
