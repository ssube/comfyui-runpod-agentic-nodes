{
  "1": {
    "class_type": "LanguageRuntime",
    "inputs": {
      "runtime": "nodejs",
      "node_major_version": 22,
      "failure_policy": "fail",
      "retry_count": 0
    }
  },
  "2": {
    "class_type": "Package",
    "inputs": {
      "previous": [
        "1",
        0
      ],
      "package_manager": "apt",
      "packages": "ca-certificates curl git jq gnupg",
      "failure_policy": "fail",
      "retry_count": 0
    }
  },
  "3": {
    "class_type": "BuildContainer",
    "inputs": {
      "image_tag": "docker.io/example/crag-agent-base:dev",
      "push_to_docker_hub": false,
      "dockerhub_username_env": "DOCKERHUB_USERNAME",
      "dockerhub_token_env": "DOCKERHUB_TOKEN",
      "failure_policy": "fail",
      "retry_count": 0,
      "deployment": [
        "6",
        0
      ],
      "container_runtime": "nerdctl",
