{
  "1": {
    "class_type": "Browser",
    "inputs": {
      "browser": "Neko",
      "browser_engine": "chromium",
      "placement": "own_pod"
    }
  },
  "2": {
    "class_type": "LLMServer",
    "inputs": {
      "api_auth_mode": "none",
      "api_key_secret_name": "",
      "engine": "Ollama",
      "hf_token_secret_name": "",
      "model": "smoke",
      "placement": "own_pod"
    }
  },
  "3": {
    "class_type": "Agent",
    "inputs": {
      "browser": [
        "1",
        0
      ],
      "harness": "Pi",
      "llm": [
        "2",
        0
      ],
      "model": "manual-real-api-smoke",
      "startup_mode": "manual",
      "system_prompt": "You are a Runpod smoke-test agent. Report exact command results.",
      "workspace_path": "/workspace"
    }
  },
  "4": {
    "class_type": "SSHCommand",
    "inputs": {
      "command": "echo crag-api-real-smoke && python --version && pwd && test -d /workspace",
      "failure_policy": "fail",
      "phase": "before_start",
      "retry_count": 0
    }
  },
  "5": {
    "class_type": "KeepAlive",
    "inputs": {
      "action": "stop",
      "cost_limit_usd": 0.0,
      "idle_grace_seconds": 0,
      "mode": "time",
      "time_unit": "minutes",
      "time_value": 10,
      "turn_limit": 0
    }
  },
  "6": {
    "class_type": "SSHAccess",
    "inputs": {
      "install_internal_sshd": true,
      "internal_port": 22,
      "mode": "runpod_proxy",
      "private_key_path": "~/.ssh/id_ed25519",
      "proxy_key_suffix": "64410ecc",
      "username": "root"
    }
  },
  "7": {
    "class_type": "Deploy",
    "inputs": {
      "app": [
        "3",
        0
      ],
      "commands": [
        "4",
        0
      ],
      "keep_alive": [
        "5",
        0
      ]
    }
  },
  "8": {
    "class_type": "RunOnRunpod",
    "inputs": {
      "prompt": "Run the smoke command and save the generated runtime config files.",
      "deployment": [
        "7",
        0
      ],
      "log_level": "info",
      "mode": "apply",
      "on_error": "terminate_created",
      "cloud_type": "SECURE",
      "container_disk_gb": 20,
      "expose_public_ip": true,
      "gpu_count": 1,
      "gpu_type_id": "NVIDIA RTX A4000",
      "reuse_policy": "always_create",
      "ssh_access": [
        "6",
        0
      ],
      "volume_gb": 0
    }
  }
}
