{
  "1": {
    "class_type": "RunpodSSHCommand",
    "inputs": {
      "command": "echo api-plan-smoke",
      "failure_policy": "fail",
      "order": 0,
      "phase": "before_start",
      "retry_count": 0
    }
  },
  "2": {
    "class_type": "RunpodSSHAccess",
    "inputs": {
      "install_internal_sshd": false,
      "internal_port": 22,
      "mode": "runpod_proxy",
      "private_key_path": "~/.ssh/id_ed25519",
      "proxy_key_suffix": "64410ecc",
      "username": "root"
    }
  },
  "3": {
    "class_type": "RunpodKeepAlive",
    "inputs": {
      "action": "stop",
      "cost_limit_usd": 0.0,
      "idle_grace_seconds": 0,
      "mode": "time",
      "time_unit": "minutes",
      "time_value": 15,
      "turn_limit": 0
    }
  },
  "4": {
    "class_type": "RunpodAgent",
    "inputs": {
      "harness": "Pi",
      "model": "manual-api-smoke",
      "startup_mode": "manual",
      "system_prompt": "You are a concise Runpod smoke-test agent.",
      "workspace_path": "/workspace"
    }
  },
  "5": {
    "class_type": "RunpodPod",
    "inputs": {
      "app": [
        "4",
        0
      ],
      "cloud_type": "COMMUNITY",
      "commands": [
        "1",
        0
      ],
      "container_disk_gb": 20,
      "expose_public_ip": true,
      "gpu_count": 1,
      "gpu_type_id": "NVIDIA GeForce RTX 3090",
      "keep_alive": [
        "3",
        0
      ],
      "reuse_policy": "always_create",
      "ssh_access": [
        "2",
        0
      ],
      "volume_gb": 0
    }
  },
  "6": {
    "class_type": "RunpodRun",
    "inputs": {
      "deployment": [
        "5",
        0
      ],
      "log_level": "info",
      "mode": "plan",
      "on_error": "terminate_created",
      "prompt": "Plan the smoke test deployment."
    }
  }
}
